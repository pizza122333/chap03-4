#include <iostream>
#include <opencv2/opencv.hpp>

using namespace cv;
using namespace std;

int main()
{
    // 1. 영상 불러오기
    Mat img1 = imread("C:\\Users\\chy73\\Downloads\\dog.bmp", IMREAD_COLOR);
    if (img1.empty()) {
        cerr << "Image load failed!" << endl;
        return -1;
    }

    // 2. 얼굴 영역 좌표 설정 (본인이 구한 좌표로 수정하세요!)
    Rect face_rect(116, 43, 200, 200);

    // 3. [중요] 얼굴 영역 백업받기 (깊은 복사 - copyTo 사용)
    // 원본 얼굴을 미리 따로 저장해둬야 나중에 파란색에서 다시 복구할 수 있어요.
    Mat face_backup;
    img1(face_rect).copyTo(face_backup);

    // 4. 무한 반복 (1초 간격으로 변경)
    while (true) {
        // --- (A) 얼굴을 파란색으로 만들기 ---
        Mat face = img1(face_rect); // 얕은 복사
        face.setTo(Scalar(255, 0, 0)); // 파란색으로 변경
        imshow("Blinking Dog", img1);

        // 1초(1000ms) 대기, 만약 아무 키나 누르면 종료
        if (waitKey(1000) >= 0) break;

        // --- (B) 얼굴을 원래대로 복구하기 ---
        // 백업해둔 데이터를 원본의 얼굴 위치에 다시 복사합니다.
        face_backup.copyTo(img1(face_rect));
        imshow("Blinking Dog", img1);

        // 다시 1초 대기
        if (waitKey(1000) >= 0) break;
    }

    return 0;
}
